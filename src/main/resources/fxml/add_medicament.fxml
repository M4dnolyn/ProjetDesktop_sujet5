<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="tg.univlome.epl.pharmarciemanagement.controllers.AddMedicamentController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Ajouter un médicament" />

    <GridPane hgap="10" vgap="10">
        <Label text="Code" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="codeField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Désignation" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="designationField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Quantité" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="quantiteField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Prix unitaire" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="prixField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="Date péremption" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <Button onAction="#handleSave" text="Enregistrer" />
    <Button onAction="#handleCancel" text="Annuler" />
</VBox>
