<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="tg.univlome.epl.pharmarciemanagement.controllers.LoginController">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Connexion" />

    <TextField fx:id="usernameField" promptText="Nom d'utilisateur" />

    <PasswordField fx:id="passwordField" promptText="Mot de passe" />

    <Button defaultButton="true" onAction="#handleLogin" text="Se connecter" />

    <Hyperlink onAction="#handleGoToSignUp" text="Créer un compte" />
</VBox>
