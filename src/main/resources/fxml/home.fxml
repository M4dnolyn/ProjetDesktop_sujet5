<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="tg.univlome.epl.pharmarciemanagement.controllers.HomeController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
            <Image url="/images/logo.png" />
        </ImageView>
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Gestion des médicaments" />
        <Label fx:id="welcomeLabel" text="" />
        <Button onAction="#handleLogout" text="Se déconnecter" />
    </HBox>

    <HBox spacing="20">
        <Label text="Total : " />
        <Label fx:id="totalCountLabel" text="0" />
        <Label text="Valeur stock : " />
        <Label fx:id="stockValueLabel" text="0 FCFA" />
        <Label text="Périmés : " />
        <Label fx:id="expiredCountLabel" text="0" />
    </HBox>

    <TableView fx:id="medicamentTable">
        <columns>
            <TableColumn fx:id="codeColumn" text="Code" />
            <TableColumn fx:id="designationColumn" text="Désignation" />
            <TableColumn fx:id="quantiteColumn" text="Quantité" />
            <TableColumn fx:id="prixColumn" text="Prix unitaire" />
            <TableColumn fx:id="datePeremptionColumn" text="Date péremption" />
        </columns>
    </TableView>

    <Button onAction="#handleAddMedicament" text="Ajouter un médicament" />
</VBox>
